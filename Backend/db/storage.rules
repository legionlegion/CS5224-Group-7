rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // -------------------------------------------------------
    // Recycling submission images
    // Path: /uploads/{userId}/{allPaths=**}
    // -------------------------------------------------------
    match /uploads/{userId}/{allPaths=**} {
      // Only the owning user can read their own uploaded images
      allow read: if request.auth != null && request.auth.uid == userId;

      // Signed-in users can upload their own images
      // Max file size: 10 MB
      // Allowed types: JPEG, PNG, WEBP
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size <= 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // -------------------------------------------------------
    // Public assets (e.g. avatar images, badge icons)
    // Path: /public/{filename}
    // -------------------------------------------------------
    match /public/{filename} {
      allow read: if true;
      // Only backend (Admin SDK) can write public assets
      allow write: if false;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
